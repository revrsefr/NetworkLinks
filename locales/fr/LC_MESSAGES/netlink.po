#: coremods/corecommands.py:41 coremods/corecommands.py:67
#: coremods/corecommands.py:84
msgid "Error: Not enough arguments. Needs 1: plugin name."
msgstr "Erreur : pas assez d'arguments. Requis : 1 (nom du plugin)."

#: coremods/corecommands.py:44
#, python-format
msgid "Error: %r is already loaded."
msgstr "Erreur : %r est déjà chargé."

#: coremods/corecommands.py:55
#, python-format
msgid "Loaded plugin %r."
msgstr "Plugin %r chargé."

#: coremods/corecommands.py:73
#, python-format
msgid "Unloaded plugin %r."
msgstr "Plugin %r déchargé."

#: coremods/corecommands.py:75
#, python-format
msgid "Unknown plugin %r."
msgstr "Plugin %r inconnu."

#: coremods/corecommands.py:120
#, python-format
msgid "Reloaded coremod %r."
msgstr "Coremod %r rechargé."

#: coremods/corecommands.py:138
#, python-format
msgid "Rehash complete with %d error(s): %s"
msgstr "Rechargement terminé avec %d erreur(s) : %s"

#: coremods/corecommands.py:140
msgid "Done. Reloaded config, plugins and coremods; links left intact."
msgstr ""
"Terminé. Configuration, plugins et coremods rechargés ; les liens sont "
"intacts."

#: coremods/login.py:87
msgid ""
"Cannot log in to an account with a hashed password because passlib is not "
"installed."
msgstr ""
"Impossible de se connecter à un compte avec un mot de passe haché car "
"passlib n'est pas installé."

#: coremods/login.py:95
msgid "Cannot use 'identify' via a command proxy."
msgstr "Impossible d'utiliser « identify » via un relais de commandes."

#: coremods/login.py:107
msgid "Account is not authorized to login on this network."
msgstr "Ce compte n'est pas autorisé à se connecter sur ce réseau."

#: coremods/login.py:111
msgid "You must be opered."
msgstr "Vous devez être opérateur IRC."

#: coremods/login.py:115
msgid "Hostname mismatch."
msgstr "Le nom d'hôte ne correspond pas."

#: coremods/login.py:118
#, python-format
msgid "Successfully logged in as %s."
msgstr "Connecté avec succès en tant que %s."

#: coremods/login.py:128
msgid ""
"Error: This command must be sent in private. (Would you really type a "
"password inside a channel?)"
msgstr ""
"Erreur : cette commande doit être envoyée en privé. (Taperiez-vous vraiment "
"un mot de passe dans un salon ?)"

#: coremods/login.py:134
msgid "Error: Not enough arguments."
msgstr "Erreur : pas assez d'arguments."

#: coremods/login.py:143
msgid "Bad username or password."
msgstr "Nom d'utilisateur ou mot de passe incorrect."

#: coremods/permissions.py:72
#, python-format
msgid "You are missing one of the following permissions: %s"
msgstr "Il vous manque l'une des permissions suivantes : %s"

#: plugins/antispam.py:439
msgid "No text filters set."
msgstr "Aucun filtre de texte défini."

#: plugins/antispam.py:441
#, python-format
msgid "Text filters: %s"
msgstr "Filtres de texte : %s"

#: plugins/antispam.py:446
#, python-format
msgid "Not enough arguments. Needs: %s <glob>"
msgstr "Pas assez d'arguments. Requis : %s <glob>"

