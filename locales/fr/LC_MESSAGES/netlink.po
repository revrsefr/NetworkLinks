#, python-format
msgid "NetLink hostname: %s; SID: %s; SID range: %s"
msgstr "Nom d'hôte NetLink : %s ; SID : %s ; Plage de SID : %s"

#: plugins/commands.py:209
msgid "Not enough arguments. Needs 1: channel."
msgstr "Pas assez d'arguments. Requis : 1 (salon)."

#: plugins/commands.py:212 plugins/commands.py:224 plugins/opercmds.py:122
#: plugins/opercmds.py:437 plugins/opercmds.py:495 plugins/opercmds.py:533
#, python-format
msgid "Unknown channel %r."
msgstr "Salon %r inconnu."

#: plugins/commands.py:269
#, python-format
msgid "NetLink version %s (in VCS: %s), running on Python %s."
msgstr "NetLink version %s (dans le VCS : %s), exécuté sur Python %s."

#: plugins/commands.py:270
#, python-format
msgid "The source of this program is available at %s."
msgstr "Le code source de ce programme est disponible à l'adresse %s."

#: plugins/commands.py:279
msgid "No text to send!"
msgstr "Aucun texte à envoyer !"

#: plugins/commands.py:313
msgid "You are not logged in!"
msgstr "Vous n'êtes pas connecté !"

#: plugins/commands.py:318
#, python-format
msgid "Unknown user %s."
msgstr "Utilisateur %s inconnu."

#: plugins/commands.py:324
#, python-format
msgid "%s is not logged in."
msgstr "%s n'est pas connecté."

#: plugins/commands.py:342
#, python-format
msgid "Unknown log level \"%s\"."
msgstr "Niveau de journalisation « %s » inconnu."

#: plugins/commands.py:358
msgid "Not enough arguments. (Needs 1, password)"
msgstr "Pas assez d'arguments. (Requis : 1, mot de passe)"

#: plugins/commands.py:361
msgid "Password cannot be empty."
msgstr "Le mot de passe ne peut pas être vide."

#: plugins/commands.py:365
msgid "Password encryption is not available (missing passlib)."
msgstr "Le chiffrement du mot de passe n'est pas disponible (passlib manquant)."

#: plugins/global.py:23
msgid "Refusing to send an empty message."
msgstr "Refus d'envoyer un message vide."

#: plugins/global.py:64
#, python-format
msgid "Done. Sent to %d channels across %d networks."
msgstr "Terminé. Envoyé à %d salons sur %d réseaux."

#: plugins/ignore.py:53
#, python-format
msgid "Ignored masks: %s"
msgstr "Masques ignorés : %s"

#: plugins/ignore.py:58
#, python-format
msgid "Not enough arguments. Needs: ignore %s <mask>"
msgstr "Pas assez d'arguments. Requis : ignore %s <masque>"

#: plugins/opercmds.py:49
#, python-format
msgid "Checking for hosts that match %s:"
msgstr "Recherche des hôtes correspondant à %s :"

#: plugins/opercmds.py:61
#, python-format
msgid "%s out of %s results shown."
msgstr "%s résultats affichés sur %s."

#: plugins/opercmds.py:64
msgid "No results found."
msgstr "Aucun résultat trouvé."

#: plugins/opercmds.py:69
#, python-format
msgid "Yes, %s matches %s."
msgstr "Oui, %s correspond à %s."

#: plugins/opercmds.py:71
#, python-format
msgid "No, %s does not match %s."
msgstr "Non, %s ne correspond pas à %s."

#: plugins/opercmds.py:125
#, python-format
msgid ""
"You do not have access to set bans in %s. Ask someone to op you or use the --"
"force option."
msgstr "Vous n'avez pas l'autorisation de définir des bannissements dans %s. Demandez à quelqu'un de vous opérer ou utilisez l'option --force."

#: plugins/opercmds.py:134
#, python-format
msgid "Skipping banning %s because they are opered."
msgstr "Bannissement de %s ignoré car il est opérateur IRC."

#: plugins/opercmds.py:137
#, python-format
msgid "Skipping banning %s because it is a service client."
msgstr "Bannissement de %s ignoré car c'est un client de services."

#: plugins/opercmds.py:168
#, python-format
msgid "Banned %s users on %r."
msgstr "%s utilisateurs bannis sur %r."

#: plugins/opercmds.py:247
#, python-format
msgid "Skipping killing %s because they are opered."
msgstr "Élimination de %s ignorée car il est opérateur IRC."

#: plugins/opercmds.py:250
#, python-format
msgid "Skipping killing %s because it is a service client."
msgstr "Élimination de %s ignorée car c'est un client de services."

#: plugins/opercmds.py:276
#, python-format
msgid ""
"Not kicking %s from %s because you don't have CLAIM access. If this is "
"another network's channel, ask someone to op you or use the --force-kb "
"option."
msgstr "Expulsion de %s de %s refusée car vous n'avez pas l'accès CLAIM. S'il s'agit du salon d'un autre réseau, demandez à quelqu'un de vous opérer ou utilisez l'option --force-kb."

#: plugins/opercmds.py:281
#, python-format
msgid "Skipping akill on %s because NetLink doesn't know the real host."
msgstr "Akill sur %s ignoré car NetLink ne connaît pas l'hôte réel."

#: plugins/opercmds.py:298
#, python-format
msgid "Masskilled %s/%s users."
msgstr "%s/%s utilisateurs éliminés en masse."

#: plugins/opercmds.py:335
msgid "Not enough arguments. Needs 1: user@host mask."
msgstr "Pas assez d'arguments. Requis : 1 (masque utilisateur@hôte)."

#: plugins/opercmds.py:338
msgid "Server bans aren't supported on this network."
msgstr "Les bannissements de serveur ne sont pas pris en charge sur ce réseau."

#: plugins/opercmds.py:360
msgid "Not enough arguments. Needs 1-2: servername, reason (optional)."
msgstr "Pas assez d'arguments. Requis : 1-2 (nom du serveur, raison facultative)."

#: plugins/opercmds.py:364
#, python-format
msgid "Invalid server name %r."
msgstr "Nom de serveur invalide : %r."

#: plugins/opercmds.py:393
msgid "No message given."
msgstr "Aucun message fourni."

#: plugins/opercmds.py:433
msgid "Not enough arguments. Needs 2-3: channel, target, reason (optional)."
msgstr "Pas assez d'arguments. Requis : 2-3 (salon, cible, raison facultative)."

#: plugins/opercmds.py:458
msgid "Not enough arguments. Needs 1-2: target, reason (optional)."
msgstr "Pas assez d'arguments. Requis : 1-2 (cible, raison facultative)."

#: plugins/opercmds.py:467
msgid "Cannot kill the main NetLink client!"
msgstr "Impossible d'éliminer le client principal de NetLink !"

#: plugins/opercmds.py:491
msgid "Not enough arguments. Needs 2: target, modes to set."
msgstr "Pas assez d'arguments. Requis : 2 (cible, modes à définir)."

#: plugins/opercmds.py:499 plugins/opercmds.py:508
msgid "No valid modes were given."
msgstr "Aucun mode valide n'a été fourni."

#: plugins/opercmds.py:529
msgid "Not enough arguments. Needs 2: channel, topic."
msgstr "Pas assez d'arguments. Requis : 2 (salon, sujet)."

#: plugins/opercmds.py:571
#, python-format
msgid "Not enough arguments. Needs 2: target, new %s."
msgstr "Pas assez d'arguments. Requis : 2 (cible, nouveau %s)."

