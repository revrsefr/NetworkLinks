msgstr "Sous-commande inconnue %r. Utilisez add, del ou list."

#: plugins/bots.py:20
msgid "This network does not support client spawning."
msgstr "Ce réseau ne prend pas en charge la création de clients."

#: plugins/bots.py:27
msgid "Not enough arguments. Needs 3: nick, user, host."
msgstr "Pas assez d'arguments. Requis : 3 (pseudo, utilisateur, hôte)."

#: plugins/bots.py:42
msgid "Not enough arguments. Needs 1-2: nick, reason (optional)."
msgstr "Pas assez d'arguments. Requis : 1-2 (pseudo, raison facultative)."

#: plugins/bots.py:47
#, python-format
msgid "Unknown user %r"
msgstr "Utilisateur %r inconnu"

#: plugins/bots.py:51
msgid "Cannot quit the main NetLink client!"
msgstr "Impossible de déconnecter le client principal de NetLink !"

#: plugins/bots.py:57
msgid "Cannot force quit a protected NetLink services client."
msgstr "Impossible de forcer la déconnexion d'un client de services NetLink protégé."

#: plugins/bots.py:95
msgid ""
"Not enough arguments. Needs 1-3: nick (optional), comma separated list of "
"channels, comma separated list of keys (optional)."
msgstr "Pas assez d'arguments. Requis : 1-3 (pseudo facultatif, liste de salons séparés par des virgules, liste de clés séparées par des virgules, facultative)."

#: plugins/bots.py:103 plugins/bots.py:207
msgid "No valid channels given."
msgstr "Aucun salon valide fourni."

#: plugins/bots.py:108
msgid "Cannot force join a protected NetLink services client."
msgstr "Impossible de forcer un client de services NetLink protégé à rejoindre un salon."

#: plugins/bots.py:120 plugins/bots.py:216
#, python-format
msgid "Invalid channel name %r."
msgstr "Nom de salon invalide : %r."

#: plugins/bots.py:156
msgid "Not enough arguments. Needs 1-2: nick (optional), newnick."
msgstr "Pas assez d'arguments. Requis : 1-2 (pseudo facultatif, nouveau pseudo)."

#: plugins/bots.py:164
#, python-format
msgid "Invalid nickname %r."
msgstr "Pseudo invalide : %r."

#: plugins/bots.py:168
msgid "Cannot force nick changes for a protected NetLink services client."
msgstr "Impossible de forcer le changement de pseudo d'un client de services NetLink protégé."

#: plugins/bots.py:201
msgid ""
"Not enough arguments. Needs 1-2: nick (optional), comma separated list of "
"channels."
msgstr "Pas assez d'arguments. Requis : 1-2 (pseudo facultatif, liste de salons séparés par des virgules)."

#: plugins/bots.py:211
msgid "Cannot force part a protected NetLink services client."
msgstr "Impossible de forcer un client de services NetLink protégé à quitter un salon."

#: plugins/bots.py:248
msgid "Not enough arguments. Needs 2-3: source nick (optional), target, text."
msgstr "Pas assez d'arguments. Requis : 2-3 (pseudo source facultatif, cible, texte)."

#: plugins/bots.py:252
msgid "No text given."
msgstr "Aucun texte fourni."

#: plugins/bots.py:268 plugins/commands.py:54
#, python-format
msgid "Unknown user %r."
msgstr "Utilisateur %r inconnu."

#: plugins/bots.py:271
#, python-format
msgid "Multiple users with the nick %r found: please select the right UID: %s"
msgstr "Plusieurs utilisateurs portant le pseudo %r ont été trouvés : veuillez sélectionner le bon UID : %s"

#: plugins/commands.py:31
#, python-format
msgid "You are identified as %s."
msgstr "Vous êtes identifié comme %s."

#: plugins/commands.py:33
msgid "You are not identified as anyone."
msgstr "Vous n'êtes identifié comme personne."

#: plugins/commands.py:34
#, python-format
msgid "Operator access: %s"
msgstr "Accès opérateur : %s"

#: plugins/commands.py:61
#, python-format
msgid "Showing information on user %s (%s@%s): %s"
msgstr "Informations sur l'utilisateur %s (%s@%s) : %s"

#: plugins/commands.py:123
msgid "Not enough arguments. Needs 1: nick."
msgstr "Pas assez d'arguments. Requis : 1 (pseudo)."

#: plugins/commands.py:157
#, python-format
msgid "Unknown network %r"
msgstr "Réseau %r inconnu"

#: plugins/commands.py:181
#, python-format
msgid "Information on network %s: %s"
msgstr "Informations sur le réseau %s : %s"

#: plugins/commands.py:184
#, python-format
msgid "NetLink protocol module: %s; Encoding: %s"
msgstr "Module de protocole NetLink : %s ; Encodage : %s"

